// Logik Kawalan Bahasa & Interaksi MB Legacy Store

// Fungsi untuk menukar bahasa secara dinamik
function changeLang(lang) {
    let content;
    
    // Memilih sumber data berdasarkan kod bahasa
    switch(lang) {
        case 'ms': content = ms_vault; break;
        case 'id': content = id_vault; break;
        case 'en': content = en_vault; break;
        case 'ar': content = ar_vault; break;
        case 'zh': content = zh_vault; break;
        case 'ko': content = ko_vault; break;
        case 'vi': content = vi_vault; break;
        case 'tl': content = tl_vault; break;
        default: content = en_vault;
    }

    // Mengemaskini tajuk dan senarai produk di paparan utama
    if (content && content.sentinel) {
        document.getElementById('vault-title').innerText = "✦ " + content.sentinel.title + " ✦";
        renderProducts(content);
    }
}

// Fungsi untuk memaparkan senarai produk (Dossier, Echelon, dsb)
function renderProducts(data) {
    const container = document.getElementById('product-list');
    container.innerHTML = `
        <div class="product-card" onclick="openModal('sentinel')">
            <h3>${data.sentinel.title}</h3>
            <p>${data.sentinel.desc}</p>
            <button class="golden-btn">VIEW DETAILS</button>
        </div>
    `;
}

// Fungsi untuk membuka modal maklumat produk
function openModal(type) {
    const modal = document.getElementById('productModal');
    modal.style.display = 'flex';
    // Logik tambahan untuk mengisi kandungan modal akan ditambah kemudian
}

// Menutup modal apabila klik di luar kawasan kandungan
window.onclick = function(event) {
    const modal = document.getElementById('productModal');
    if (event.target == modal) {
        modal.style.display = "none";
    }
}
