function switchTab(tab) {
    const digital = document.getElementById('digital-content');
    const merchant = document.getElementById('merchant-content');
    
    if (tab === 'digital') {
        digital.style.display = 'block';
        if(merchant) merchant.style.display = 'none';
    } else {
        digital.style.display = 'none';
        if(merchant) merchant.style.display = 'block';
    }
}

